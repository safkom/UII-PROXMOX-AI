# Proxmox
PROXMOX_URL=https://192.168.1.147:8006
PROXMOX_REALM=pve
PROXMOX_USER=k
PROXMOX_TOKEN_ID=k
# Fill this in with your real Proxmox API token secret.
# Required token privileges: Sys.Audit + VM.Audit (inventory) and
# VM.PowerMgmt (start/stop guests via the API).
PROXMOX_TOKEN_SECRET=
# SSH password for command execution on the Proxmox node
PROXMOX_PASSWORD=
# Unix login for SSH execution (separate from the API token user above).
# Without this, the API user name is used, which usually is NOT a Unix account.
PROXMOX_SSH_USER=root
# Recommended: set to true with a valid/pinned certificate. Left false only to
# accommodate self-signed homelab certs — it disables TLS validation.
PROXMOX_VERIFY_SSL=false
# Seconds before a Proxmox API request times out (prevents a hung host from
# blocking the worker thread).
PROXMOX_REQUEST_TIMEOUT=15
# Recommended: set to true and pre-populate ~/.ssh/known_hosts to reject
# unknown SSH host keys (MITM protection). false keeps the auto-accept behavior.
PROXMOX_SSH_STRICT_HOST_KEY=false

# Qdrant
QDRANT_URL=http://192.168.1.239:6333
QDRANT_API_KEY=
QDRANT_CURRENT_COLLECTION_NAME=infrastructure_current
QDRANT_HISTORY_COLLECTION_NAME=infrastructure_history
QDRANT_LOGS_COLLECTION_NAME=logs_current

# Ollama (LLM)
OLLAMA_URL=http://192.168.1.229:11434
OLLAMA_MODEL=gemma4:e4b
# Embedding model for RAG — install with: ollama pull nomic-embed-text
OLLAMA_EMBED_MODEL=nomic-embed-text
# Context window per request; keep modest on small GPUs (Quadro P2000 etc.)
OLLAMA_NUM_CTX=4096

# Loki
LOKI_URL=http://192.168.1.174:3100

# Prometheus
PROMETHEUS_URL=http://192.168.1.92:9090

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APPROVAL_DB_PATH=data/approvals.sqlite3

# Optional API authentication. When set, every API request must send
# `Authorization: Bearer <token>` (or `X-API-Key: <token>`). Leave empty for
# the trusted-LAN, no-auth mode. Strongly recommended if the port is reachable
# by anything you do not fully trust. Enter the same value in the UI settings.
API_AUTH_TOKEN=
